# Local/Codex default: run against the Compose Postgres and deterministic YouTube fixtures.
BIZEYE_DB_DRIVER=postgres
DATABASE_URL=postgresql://bizeye:bizeye_dev_password@localhost:54322/bizeye
YOUTUBE_API_MODE=mock
YOUTUBE_API_KEY=

# Production/Vercel default: set BIZEYE_DB_DRIVER=supabase and fill these server-only values.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

BIZEYE_FRONTEND_ORIGIN=http://localhost:5173,http://localhost:5190
SESSION_COOKIE_NAME=bizeye_admin_session
CRON_SECRET=local-cron-secret
